{% macro serviceOutcomeCard(item) %}
  <article class="border-brand-ink/10 rounded-3xl border p-6">
    <p class="text-brand-ink/70 text-sm font-semibold">{{ item.label }}</p>
    <p class="font-heading mt-3 text-xl font-bold tracking-tight">{{ item.title }}</p>
  </article>
{% endmacro %}

{% macro serviceFeatureCard(item) %}
  <article class="bg-brand-ink/5 rounded-3xl p-6">
    <h3 class="text-xl font-bold tracking-tight">{{ item.title }}</h3>
    <p class="text-brand-ink/80 mt-3 text-sm leading-relaxed">{{ item.description }}</p>
  </article>
{% endmacro %}

{% macro serviceStepCard(step, index) %}
  <article class="rounded-3xl bg-white/10 p-6">
    <p class="text-brand-white/70 text-sm">
      {{ '0' ~ (index + 1) if (index + 1) < 10 else (index + 1) }}
    </p>
    <h3 class="mt-3 text-xl font-bold tracking-tight">{{ step.title }}</h3>
    <p class="text-brand-white/80 mt-2 text-sm leading-relaxed">{{ step.description }}</p>
  </article>
{% endmacro %}

{% macro faqItem(item) %}
  <details class="border-brand-ink/10 rounded-3xl border p-6">
    <summary class="cursor-pointer list-none pr-8 text-base font-semibold">
      {{ item.q }}
    </summary>
    <p class="text-brand-ink/80 mt-4 text-sm leading-relaxed sm:text-base">
      {{ item.a }}
    </p>
  </details>
{% endmacro %}

{% macro homeProcessStep(step, index) %}
  {% set stepLabel = '0' ~ (index + 1) if (index + 1) < 10 else (index + 1) %}

  <article
    class="group border-brand-ink/10 bg-brand-white hover:border-brand-blue relative overflow-hidden rounded-3xl border p-8 transition duration-200 ease-out hover:-translate-y-2"
  >
    <span
      aria-hidden="true"
      class="text-brand-ink/5 pointer-events-none absolute -top-8 -right-1 text-8xl leading-none font-extrabold tracking-tight"
    >
      {{ stepLabel }}
    </span>

    <span
      class="bg-brand-lime text-brand-ink ring-brand-ink/10 relative inline-flex h-10 w-10 items-center justify-center rounded-full text-sm font-bold ring-1"
    >
      {{ stepLabel }}
    </span>

    <h3 class="font-heading mt-6 text-xl font-bold tracking-tight">
      {{ step.title }}
    </h3>
    <p class="text-brand-ink/80 mt-3 text-sm leading-relaxed">
      {{ step.description }}
    </p>
  </article>
{% endmacro %}

{% macro socialProofAvatar(client) %}
  <img
    src="{{ client.imageSrc | url }}"
    alt="{{ client.imageAlt }}"
    class="border-brand-white h-10 w-10 rounded-full border-3 object-cover"
    loading="lazy"
    decoding="async"
  />
{% endmacro %}

{% macro heroQuickAction(action) %}
  {% set isPhone = action.type == 'phone' %}

  <a
    href="{{ action.href }}"
    {% if action.external %}
      target="_blank"
      rel="noreferrer"
    {% endif %}
    aria-label="{{ action.ariaLabel or action.label }}"
    class="
      {% if isPhone %}
        text-brand-ink border-brand-ink/35 bg-brand-white hover:bg-brand-ink hover:text-brand-white hover:border-brand-ink inline-flex min-h-12 min-w-0 items-center justify-center gap-2 rounded-full border px-2.5 py-3.5 text-sm font-bold shadow-[0_0.25rem_0.7rem_rgba(35,39,51,0.12)] transition sm:px-4 sm:text-sm lg:px-0
      {% else %}
        text-brand-ink/70 border-brand-ink/15 bg-brand-white/70 hover:text-brand-ink hover:border-brand-ink/35 hover:bg-brand-white inline-flex min-h-12 min-w-0 items-center justify-center gap-2 rounded-full border px-2.5 py-3 text-sm font-semibold transition sm:px-4 sm:text-sm lg:col-span-2
      {% endif %}
    "
  >
    <i class="{{ action.icon }} text-base"></i>
    <span class="{% if isPhone %}hidden truncate sm:inline lg:hidden{% else %}hidden truncate sm:inline{% endif %}">
      {{ action.label }}
    </span>
  </a>
{% endmacro %}

{% macro contactPanelAction(action) %}
  <a
    href="{{ action.href }}"
    {% if action.external %}
      target="_blank"
      rel="noreferrer"
    {% endif %}
    class="bg-brand-ink/10 hover:bg-brand-ink/20 flex items-center justify-between rounded-3xl px-6 py-5 font-semibold transition"
  >
    <span>{{ action.label }}</span>
    <span class="flex items-center gap-3 text-sm">
      {{ action.value }}
      <i class="{{ action.icon }}"></i>
    </span>
  </a>
{% endmacro %}
