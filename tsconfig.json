{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "skipLibCheck": true,
    "noEmitOnError": true,
    "sourceMap": true,
    "rootDir": "src/assets/ts",
    "outDir": "src/assets/js"
  },
  "include": ["src/assets/ts/**/*.ts"]
}
